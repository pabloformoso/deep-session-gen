# ApolloAgents — environment variables
# Copy this file to .env and fill in your keys

# LLM provider — set at least one
# Anthropic (Claude) — recommended for the agent
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — used for DALL-E 3 artwork generation
# Also works as the agent LLM if ANTHROPIC_API_KEY is not set
OPENAI_API_KEY=sk-...

# Optional: override the agent model
# AGENT_MODEL=claude-opus-4-6
# AGENT_MODEL=gpt-4o-mini
