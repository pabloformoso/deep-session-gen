tracks/**/*.mp3
tracks/**/*.flac
tracks/**/*.m4a
tracks/**/*.ogg
tracks/**/videos/
vids/

# macOS metadata
.DS_Store
tracks/.DS_Store

# Claude project config
.claude/

# Agent session memory (personal history)
agent/memory.json
